# Discord webhook URL for the support contact form (api/contact.js).
#
# Setup:
# 1. In Discord, go to the private/admin-only channel you want submissions
#    to land in -> Edit Channel -> Integrations -> Webhooks -> New Webhook.
# 2. Copy the webhook URL and set it below (locally) or in
#    Vercel -> Project Settings -> Environment Variables (for deploys).
# 3. Never commit the real value — this file is just a template.
DISCORD_WEBHOOK_URL=
